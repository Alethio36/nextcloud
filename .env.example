# ─────────────────────────────────────────────────────────────────────────────
# REFERENCE ONLY. Do not edit this file for your install.
# `./install.sh install` generates a real .env from your answers + this template.
# .env is gitignored; this .env.example is committed so the repo documents every
# key. Values here are placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Project / paths ──
PROJECT_NAME=nextcloud
# Where bind-mount data lives. Kept OUTSIDE the git clone on purpose, so a stray
# `git clean` can never delete your files.
DATA_ROOT=/opt/nextcloud-data
TZ=Etc/UTC

# ── Domain (asked at install) ──
DOMAIN=example.com
CLOUD_HOST=cloud.example.com
OFFICE_HOST=office.example.com
TRAEFIK_HOST=traefik.example.com
SIGNAL_HOST=signal.example.com
ACME_EMAIL=admin@example.com

# ── TLS mode: cloudflare (DNS-01) or http (HTTP-01 fallback) ──
TLS_MODE=cloudflare
# Cloudflare API token with Zone:DNS:Edit (only used when TLS_MODE=cloudflare)
CF_DNS_API_TOKEN=

# ── Docker network subnets (must not collide with existing networks) ──
FRONTEND_SUBNET=172.20.0.0/24
BACKEND_SUBNET=172.21.0.0/24

# ── notify_push binary arch (auto-detected: x86_64 or aarch64) ──
NOTIFY_PUSH_ARCH=x86_64

# ── Database ──
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=

# ── Redis ──
REDIS_PASSWORD=

# ── Nextcloud admin (you must provide the password) ──
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=

# ── SMTP (asked at install) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_NAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=cloud
MAIL_DOMAIN=example.com

# ── Collabora admin console ──
COLLABORA_USERNAME=admin
COLLABORA_PASSWORD=

# ── Talk HPB secrets ──
TURN_SECRET=
SIGNALING_SECRET=
INTERNAL_SECRET=

# ── Traefik dashboard basic-auth ──
# htpasswd -nbB admin 'pw'  then DOUBLE every $ to $$ (Compose interpolates .env)
TRAEFIK_DASHBOARD_AUTH=
