# Pinned container image versions — the known-good set this repo ships with.
# Committed to git on purpose: a fresh clone reproduces a tested stack.
# `./install.sh check-updates` reports newer tags; `./install.sh update` bumps
# these (with a backup and a major-version guard). Sourced + exported by the
# script so Compose uses them for interpolation.

TRAEFIK_VERSION=v3.7.5
POSTGRES_VERSION=17
REDIS_VERSION=8.8-alpine
NEXTCLOUD_VERSION=33-apache
COLLABORA_VERSION=25.04.9.4.1
AIO_TALK_VERSION=20260527_140826
ELASTICSEARCH_VERSION=8.19.16
CLAMAV_VERSION=1.4_base
